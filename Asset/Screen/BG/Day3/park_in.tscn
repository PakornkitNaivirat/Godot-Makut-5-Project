next_scene_path = "res://Asset/Screen/BG/Cutscreen/cut_scene_concert.tscn"
dialog_text = Array[String](["Narrator: (I wonder if these are the club members? )", "Narrator: (Well, only one way to find out.)", "Player:Um... excuse me, ", "Player:are you with the Marine Conservation Club?", "NPC: Hm?", "NPC:Ah, yes! You must be the other new member.", "NPC:Glad to meet you. I’m Kla, the club president", "Player:Nice to meet you! My name is Time", "Narrator:The others took turns introducing themselves ", "Narrator:until  it  reached the last person", "NPC:Alright everyone .I’d like to announce our first club activity", "NPC:Next Saturday, we’re having an event at Bang Saen Beach.", "NPC: I’ll send the full details in the group chat later", "Narrator:\"Understood!\" everyone replied in unison.
", "NPC:Okay, that’s all for today. ", "NPC:You guys can head back or keep exploring. I'm taking off now.", "Narrator:(Should we head back now?)", "Narrator:(I don't think so. I think I'll go to a concert for a while.)"])

